coverage
*.lcov

# Dependency directories
node_modules/

# TypeScript v1 declaration files
typings/

# TypeScript cache
*.tsbuildinfo

# dotenv environment variables file
.env
.env.test

# parcel-bundler cache (https://parceljs.org/)
.cache

# ignore files generated by build process
/client/static/
/server/dist/
/e2e/static/

# Playwright test results and reports
/test-results/
/playwright-report/
/e2e/test-results/
/e2e/playwright-report/

