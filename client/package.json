{
  "name": "@web/client",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "watch:run": "run-p 'watch:run:**'",
    "watch:run:html": "mkdir -p static && cp src/index.html static/index.html",
    "watch:run:image": "mkdir -p static && bun run bin/image.ts",
    "watch:run:public": "mkdir -p static && cp -r public/. static/",
    "watch:run:bundle": "bun build --watch --sourcemap=inline --outdir=static/ src/index.tsx",
    "watch:run:tailwind": "tailwindcss --watch --input src/index.css --output static/index.css",
    "build": "run-p 'build:**'",
    "build:html": "mkdir -p static && cp src/index.html static/index.html",
    "build:image": "mkdir -p static && bun run bin/image.ts",
    "build:public": "mkdir -p static && cp -r public/. static/",
    "build:bundle": "NODE_ENV=production bun build --minify --outdir=./static/ src/index.tsx",
    "build:tailwind": "tailwindcss --minify --input src/index.css --output ./static/index.css",
    "check:lint": "biome check .",
    "check:test": "bun test src/",
    "check:type": "tsc --noEmit",
    "fix:lint": "biome check --write .",
    "watch:test": "bun test --watch src/",
    "watch:type": "tsc --noEmit --watch"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "i18next": "^26.0.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.1"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.8.9",
    "@tailwindcss/cli": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "bun-bagel": "^1.2.0",
    "happy-dom": "^20.8.9",
    "npm-run-all2": "^8.0.4",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  }
}
